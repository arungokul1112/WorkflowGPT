{
  "name": "workflow-gpt-backend",
  "version": "1.0.0",
  "description": "AI Workflow Automation Agent Backend",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "client": "npm run dev --prefix client",
    "dev:full": "concurrently \"npm run dev\" \"npm run client\"",
    "build": "tsc",
    "seed": "ts-node src/seed.ts"
  },
  "dependencies": {
    "@types/socket.io": "^3.0.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "groq-sdk": "^0.3.3",
    "helmet": "^7.1.0",
    "mongoose": "^8.3.2",
    "morgan": "^1.10.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.12.7",
    "concurrently": "^9.2.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
